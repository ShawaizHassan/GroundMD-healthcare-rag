# ── LLM (Ollama) ──────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TEMPERATURE=0.1
OLLAMA_MAX_TOKENS=1024

# ── Embedding model ───────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# ── Vector database (ChromaDB) ────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=healthcare_docs

# ── Ingestion settings ────────────────────────────────────
DOCS_DIR=./data/raw
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ── Retriever settings ────────────────────────────────────
RETRIEVER_TOP_K=5
RETRIEVER_SCORE_THRESHOLD=0.4

# ── FastAPI backend ───────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# ── App settings ──────────────────────────────────────────
APP_NAME=Healthcare RAG System
APP_ENV=development
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_MB=50